# ======================================
# ZS-RAG Environment Configuration
# ======================================
# Copy this file to .env and update values as needed
# cp .env.template .env

# ======================================
# Application Settings
# ======================================
APP_NAME=zs-rag
APP_ENV=development

# ======================================
# Backend Settings
# ======================================
BACKEND_TARGET=development
BACKEND_PORT=8000
# 离线构建后端镜像时使用 Dockerfile.local（需先有 backend/offline_deps/）
# BACKEND_DOCKERFILE=Dockerfile.local

# ======================================
# Frontend Settings
# ======================================
FRONTEND_TARGET=development
FRONTEND_PORT=80
# IMPORTANT: Change this to your server IP for remote access
VITE_API_BASE_URL=http://192.168.11.19:8000
# 前端 Axios：普通请求超时（毫秒）
# VITE_HTTP_TIMEOUT_MS=30000
# 文档上传 / 重建索引（后端同步解析与索引，大文件耗时长）
# VITE_LONG_REQUEST_TIMEOUT_MS=900000

# ======================================
# Database Settings (PostgreSQL)
# ======================================
POSTGRES_DB=zs_rag
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# 连接串（可选）。一般不必设置：docker compose 会为 backend 注入指向服务名 postgres 的 DATABASE_URL。
# 在本机直接运行 uvicorn（非 Docker）时请使用 localhost，例如：
# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/zs_rag
#
# 若在容器内使用主机名 postgres，必须与其它服务在同一 Docker 网络（例如 docker compose up），
# 否则会出现：Name or service not known。
#
# 若 POSTGRES_PASSWORD 含 @ : / # 等字符，compose 拼出的 URL 会错位；请改用不含特殊字符的密码或对密码做 URL 编码。

# ======================================
# Security Settings
# ======================================
# IMPORTANT: Change these in production!
JWT_SECRET=change-me-in-production
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!

# ======================================
# CORS Settings
# ======================================
# Add your server IP and any other domains you'll access from
CORS_ORIGINS=http://192.168.11.19,http://192.168.11.19:80,http://192.168.11.19:5173,http://localhost:5173,http://localhost:80

# ======================================
# Milvus Settings
# ======================================
MILVUS_HOST=milvus
MILVUS_PORT=19530
MILVUS_USERNAME=
MILVUS_PASSWORD=

# ======================================
# Neo4j Settings
# ======================================
NEO4J_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=neo4jpassword
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687

# ======================================
# MinIO Settings (for Milvus)
# ======================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ======================================
# MinerU（PDF / 图片解析；可选）
# --------------------------------------
# 开启步骤：
# 1) 把 MINERU_ENABLED 设为 true
# 2) 拉起 sidecar：docker compose --profile mineru up -d --build mineru
# 3) 首次启动会下载模型（~数 GB）到 mineru_models 卷，可通过 MINERU_MODEL_SOURCE 切换来源
# 当 backend 连不上 mineru 时，PDF 会自动降级到 pypdf；图片解析则直接报错（目前无降级路径）
# ======================================
MINERU_ENABLED=false
MINERU_BASE_URL=http://mineru:8000
# pipeline（CPU/GPU 轻量，推荐默认）| vlm-vllm-engine（需 GPU，高精度 VLM）
MINERU_BACKEND=pipeline
# OCR 语言：ch/en/korean/japan...
MINERU_LANG=ch
# 单文件解析超时（秒）。扫描件/大 PDF 建议调大
MINERU_TIMEOUT=300
# backend 只会把以下后缀的文件交给 MinerU；DOCX/XLSX/PPTX 仍走本地解析器
MINERU_FORMATS=pdf,png,jpg,jpeg,bmp,tif,tiff,webp
# 模型下载源：modelscope（国内快）| huggingface
MINERU_MODEL_SOURCE=modelscope
# sidecar 对外映射端口（默认 8001，避免与 backend 的 8000 冲突）
MINERU_PORT=8001

# ======================================
# Production Environment Variables
# (Uncomment and set these for production)
# ======================================
# JWT_SECRET=your-super-secret-key-change-in-production
# ADMIN_PASSWORD=your-secure-password
# POSTGRES_PASSWORD=your-secure-postgres-password
# NEO4J_PASSWORD=your-secure-neo4j-password
# MINIO_ROOT_PASSWORD=your-secure-minio-password
# VITE_API_BASE_URL=https://your-domain.com/api
