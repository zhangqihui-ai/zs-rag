# ======================================
# ZS-RAG Environment Configuration
# ======================================
# 开发 / 生产部署均使用本模板：
#   cp .env.template .env
#
# 开发：docker compose up -d
# 生产离线（目标机仅需 compose + .env，无需源码）：
#   APP_ENV=production，并调整下方端口、CORS、密码
#   docker compose -f docker-compose.prod.yml -f docker-compose.prod.registry.yml pull
#   docker compose -f docker-compose.prod.yml -f docker-compose.prod.registry.yml up -d --no-build
#   docker compose -f docker-compose.prod.yml -f docker-compose.prod.registry.yml exec backend python -m alembic upgrade head
#
# 生产启用 MinerU：MINERU_ENABLED=true；构建机推 CPU：--mineru-only，推 GPU：--mineru-gpu-only
#   CPU: docker compose -f docker-compose.prod.yml -f docker-compose.prod.registry.yml --profile mineru up -d --no-build
#   GPU: docker compose ... --profile mineru-gpu up -d --no-build（宿主机需 nvidia-container-toolkit）
#   改 MINERU_* 后须 force-recreate backend

# ======================================
# Application Settings
# ======================================
APP_NAME=zs-rag
APP_ENV=development

# ======================================
# Private Registry（配合 docker-compose.prod.registry.yml / docker-compose.registry.yml）
# ======================================
REGISTRY=192.168.252.252:5566
IMAGE_NAMESPACE=zs-rag

# ======================================
# Backend Settings
# ======================================
BACKEND_TARGET=development
BACKEND_PORT=8000
# 内网离线构建 / push 脚本加 --offline 时使用（需 backend/offline_deps/ 与 offline_deps/jre/）
# BACKEND_DOCKERFILE=Dockerfile.local
# 内网 push 示例：./scripts/push-images-to-registry.sh --offline

# ======================================
# Frontend Settings
# ======================================
FRONTEND_TARGET=development
FRONTEND_PORT=80
# Dev Docker Compose (npm run dev in frontend container):
#   Leave VITE_API_BASE_URL empty — browser uses same origin, Vite proxy forwards to backend:8000.
# Production Docker (frontend nginx proxies API to backend):
#   Leave VITE_API_BASE_URL empty — browser uses same origin, nginx forwards to backend:8000.
# Dev / direct backend access (no proxy):
#   VITE_API_BASE_URL=http://192.168.11.19:8000
# Alternative prod (explicit backend URL, skip nginx proxy):
#   VITE_API_BASE_URL=http://YOUR_IP:BACKEND_PORT
VITE_API_BASE_URL=
# 前端 Axios：普通请求超时（毫秒）
# VITE_HTTP_TIMEOUT_MS=30000
# 文档上传 / 重建索引（后端同步解析与索引，大文件耗时长）
# VITE_LONG_REQUEST_TIMEOUT_MS=900000

# ======================================
# Database Settings (PostgreSQL)
# ======================================
POSTGRES_DB=zs_rag
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# 连接串（可选）。一般不必设置：docker compose 会为 backend 注入指向服务名 postgres 的 DATABASE_URL。
# 在本机直接运行 uvicorn（非 Docker）时请使用 localhost，例如：
# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/zs_rag
#
# 若在容器内使用主机名 postgres，必须与其它服务在同一 Docker 网络（例如 docker compose up），
# 否则会出现：Name or service not known。
#
# 若 POSTGRES_PASSWORD 含 @ : / # 等字符，compose 拼出的 URL 会错位；请改用不含特殊字符的密码或对密码做 URL 编码。

# ======================================
# Security Settings
# ======================================
# IMPORTANT: Change these in production!
JWT_SECRET=change-me-in-production
# 可选：嵌入 API Key 哈希加盐（为空则使用 JWT_SECRET）
EMBED_API_KEY_PEPPER=
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!

# ======================================
# CORS Settings
# ======================================
# CORS_ORIGINS：额外白名单（逗号分隔，完整 origin）。不能写 * 通配符。
# CORS_ALLOW_LAN_REGEX=true（默认）时，已自动放行：
#   http://localhost:* 、http://127.0.0.1:* 、http://192.168.x.x:* 任意端口
# 公网暴露若需收紧可设 CORS_ALLOW_LAN_REGEX=false，并只保留明确域名。
CORS_ALLOW_LAN_REGEX=true
CORS_ORIGINS=http://192.168.11.19,http://192.168.11.19:80,http://192.168.252.115:8090,http://localhost,http://localhost:80

# ======================================
# Milvus Settings
# ======================================
MILVUS_HOST=milvus
MILVUS_PORT=19530
MILVUS_DB_NAME=default
MILVUS_USERNAME=
MILVUS_PASSWORD=

# ======================================
# Neo4j Settings
# ======================================
NEO4J_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=neo4jpassword
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687

# ======================================
# LightRAG / tiktoken
# ======================================
# 默认 false：使用离线字符分词，入库时不访问 openaipublic.blob.core.windows.net
# 若设为 true，须预置 TIKTOKEN_CACHE_DIR 离线缓存（有网机器执行 python -m lightrag.tools.download_cache）
LIGHTRAG_USE_TIKTOKEN=false
# TIKTOKEN_CACHE_DIR=/app/offline_deps/tiktoken-cache

# ======================================
# MinIO Settings (for Milvus)
# ======================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ======================================
# MinerU（PDF / 图片解析；可选）
# --------------------------------------
# 开启步骤：
# 1) MINERU_ENABLED=true
# 2) 选 CPU 或 GPU（二选一，不要同时起两个 MinerU 占同一张卡）：
#    CPU：MINERU_BASE_URL=http://mineru:8000，MINERU_BACKEND=pipeline
#         docker compose --profile mineru up -d mineru
#    GPU：MINERU_BASE_URL=http://mineru-gpu:8000，MINERU_BACKEND=vlm-vllm-engine
#         docker compose --profile mineru-gpu up -d mineru-gpu
# 3) 改 .env 后须 force-recreate backend
# 4) 离线 prod（模型打进独立 tag，构建快，不改动 mineru:cpu）：
#    ./scripts/export-mineru-models-bundle.sh
#    ./scripts/push-images-to-registry.sh --offline --mineru-offline-only
#    MINERU_CPU_IMAGE=.../mineru:cpu-offline  MINERU_MODEL_SOURCE=local
#    prod compose 已默认不挂 mineru_models 卷（空卷会盖住镜像内模型）
# ======================================
MINERU_ENABLED=false
MINERU_CPU_IMAGE=192.168.252.252:5566/zs-rag/mineru:cpu
# 离线含模型镜像（见 Dockerfile.mineru-cpu-offline / --mineru-offline-only）：
# MINERU_CPU_IMAGE=192.168.252.252:5566/zs-rag/mineru:cpu-offline
MINERU_GPU_IMAGE=192.168.252.252:5566/zs-rag/mineru:gpu
# 与上方 profile 对应的服务名（compose 网络 DNS）
MINERU_BASE_URL=http://mineru:8000
# pipeline（CPU sidecar）| vlm-vllm-engine（GPU sidecar + T4 等，显存建议 ≥8GB）
MINERU_BACKEND=pipeline
# OCR 语言：ch/en/korean/japan...
MINERU_LANG=ch
# 单文件解析超时（秒）。扫描件/大 PDF 建议调大
MINERU_TIMEOUT=300
# MinerU 可解析后缀白名单；知识库 parsers.*.engine=mineru 时须在此列表内
MINERU_FORMATS=pdf,png,jpg,jpeg,bmp,tif,tiff,webp,docx,xlsx,xlsm,xls,csv,md,txt
# 模型下载源：modelscope（国内快）| huggingface
MINERU_MODEL_SOURCE=modelscope
# 使用 mineru:cpu-offline 时改为 local（镜像内须含 /models/mineru.json，见 generate-mineru-local-config.sh）
# sidecar 对外映射端口（CPU 8001 / GPU 8002，避免与 backend 8000 冲突）
MINERU_PORT=8001
MINERU_GPU_PORT=8002
# GPU 容器可见设备（宿主机多卡时改为 0,1 等；compose deploy 默认预留 1 张卡）
MINERU_GPU_DEVICES=0
# 离线构建 GPU：先 sync vllm 基础镜像，构建时设 MINERU_VLLM_BASE_IMAGE
#   ./scripts/sync-registry-image.sh vllm/vllm-openai:v0.11.2 vllm-openai:v0.11.2
# MINERU_VLLM_BASE_IMAGE=192.168.252.252:5566/zs-rag/vllm-openai:v0.11.2
# 内网无法 apt 时：MINERU_GPU_SKIP_APT=1 ./scripts/push-images-to-registry.sh --offline --mineru-gpu-only
# 或 docker build ... --build-arg SKIP_APT_PACKAGES=1 --build-arg APT_MIRROR=mirrors.aliyun.com

# ======================================
# OpenDataLoader PDF（PDF 默认解析引擎；本地 CPU + JVM）
# --------------------------------------
# PDF 默认走进程内 SDK（需 backend 镜像内 JRE 11+）。
# 图片仍使用 MinerU（上方 MINERU_ENABLED）。
# Hybrid：扫描件/复杂表格，需 sidecar：
#   docker compose --profile odl-hybrid up -d opendataloader-hybrid
# ======================================
ODL_ENABLED=true
ODL_DEFAULT_PARSER=opendataloader
ODL_HYBRID=false
ODL_HYBRID_URL=http://opendataloader-hybrid:5002
ODL_TIMEOUT=120
ODL_HYBRID_PORT=5002

# ======================================
# Redis / Celery / 配额与限流
# ======================================
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
# 开发默认关闭 Celery；生产可设为 true 并 docker compose --profile celery up -d celery-worker
# celery-worker 与 backend 共用 BACKEND_IMAGE，无需单独构建 celery 镜像
CELERY_ENABLED=false
# Celery worker 并发进程数（生产可按 CPU 核数调大，如 16 / 32）
CELERY_WORKER_CONCURRENCY=8
RATE_LIMIT_ENABLED=true
CHAT_API_RATE_LIMIT_PER_MINUTE=120
AUTH_LOGIN_RATE_LIMIT_PER_MINUTE=30
EMBED_API_KEY_DAILY_QUOTA=5000
# 企业空间配额（0=不限制）
SPACE_MAX_DOCUMENTS=0
SPACE_MAX_STORAGE_BYTES=0

# ======================================
# Prod 离线部署补充说明（示例：目标机 192.168.252.115）
# ======================================
# APP_ENV=production
# FRONTEND_PORT=8090
# BACKEND_PORT=8091
# CORS_ORIGINS=http://192.168.252.115:8090
# POSTGRES_PASSWORD / JWT_SECRET / ADMIN_PASSWORD / NEO4J_PASSWORD / MINIO_ROOT_PASSWORD 务必修改
#
# 前端 API 地址在「构建 frontend:prod 镜像」时写入（非运行时 .env）：
#   推荐留空 VITE_API_BASE_URL=，由 frontend nginx 同源反代 backend（见 web/nginx.conf）
#   cd web && npm run build:deploy
#   ./scripts/push-images-to-registry.sh --offline
# 若不经 nginx 反代，构建时显式指定后端地址：
#   cd web && VITE_API_BASE_URL=http://192.168.252.115:8091 npm run build:deploy
