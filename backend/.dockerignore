# Backend .dockerignore

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
tests/

# 构建上下文瘦身（deps 阶段仍用 offline_deps/；下列目录不打进 COPY 层）
storage/
# mineru_models_bundle 仅用于 Dockerfile.mineru-cpu-offline，经 --build-context 传入，此处排除以减小 backend 构建上下文
mineru_models_bundle/
# MinerU 离线镜像需要的脚本仍须打进 context
scripts/**
!scripts/generate-mineru-local-config.sh
!scripts/mineru-api-entrypoint.sh

# Misc
.git
.gitignore
.dockerignore
.env.template
*.md
Makefile
docker-compose*.yml
Dockerfile*
!Dockerfile.local
